<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:clipChildren="false"
		android:clipToPadding="false"
		android:fitsSystemWindows="true">

	<!-- 手表版：缩小按钮尺寸 -->
	<ImageButton
		android:id="@+id/settingsButton"
		android:layout_width="36dp"
		android:layout_height="36dp"
		android:layout_margin="10dp"
		android:background="@drawable/bg_icon_button"
		android:contentDescription="@string/settings"
		android:padding="7dp"
		android:src="@drawable/ic_settings"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:tint="@color/expressive_on_surface" />

	<ImageButton
		android:id="@+id/distanceMaskToggleButton"
		android:layout_width="36dp"
		android:layout_height="36dp"
		android:layout_marginEnd="4dp"
		android:background="@drawable/bg_icon_button"
		android:contentDescription="@string/distance_mask_button_content_description_off"
		android:padding="7dp"
		android:src="@drawable/ic_visibility_off"
		app:layout_constraintBottom_toBottomOf="@id/settingsButton"
		app:layout_constraintEnd_toStartOf="@id/settingsButton"
		app:layout_constraintTop_toTopOf="@id/settingsButton"
		app:tint="@color/expressive_on_surface" />

	<LinearLayout
		android:id="@+id/centerContent"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:gravity="center_horizontal"
		android:orientation="vertical"
		android:padding="12dp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent">

		<ImageView
			android:id="@+id/arrowView"
			android:layout_width="160dp"
			android:layout_height="160dp"
			android:contentDescription="@string/arrow"
			android:padding="10dp"
			android:scaleType="centerInside"
			android:src="@drawable/yjsnpi" />

		<TextView
			android:id="@+id/distanceText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:fontFamily="@font/noto_sans_jp"
			android:text="@string/waiting_location"
			android:textColor="@color/expressive_on_surface"
			android:textLocale="ja-JP"
			android:textSize="28sp"
			android:textStyle="bold" />

		<TextView
			android:id="@+id/directionText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="6dp"
			android:fontFamily="@font/noto_sans_jp"
			android:text="@string/direction_placeholder"
			android:textColor="@color/expressive_on_surface_variant"
			android:textLocale="ja-JP"
			android:textSize="20sp" />
	</LinearLayout>

	<LinearLayout
		android:id="@+id/arrivalContent"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:gravity="start"
		android:orientation="vertical"
		android:padding="12dp"
		android:visibility="gone"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent">

		<TextView
			android:id="@+id/arrivalTitleText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center_horizontal"
			android:fontFamily="@font/noto_sans_jp"
			android:gravity="center_horizontal"
			android:text="@string/arrival_title"
			android:textAlignment="center"
			android:textColor="@color/expressive_on_surface"
			android:textLocale="ja-JP"
			android:textSize="32sp"
			android:textStyle="bold" />

		<TextView
			android:id="@+id/arrivalNameText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:fontFamily="@font/noto_sans_jp"
			android:gravity="start"
			android:text="@string/arrival_name_placeholder"
			android:textAlignment="viewStart"
			android:textColor="@color/expressive_on_surface_variant"
			android:textLocale="ja-JP"
			android:textSize="18sp"
			android:textStyle="bold" />

		<TextView
			android:id="@+id/arrivalCoordsText"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:fontFamily="@font/noto_sans_mono"
			android:gravity="start"
			android:text="@string/arrival_coords_placeholder"
			android:textAlignment="viewStart"
			android:textColor="@color/expressive_on_surface_variant"
			android:textLocale="ja-JP"
			android:textSize="12sp" />

		<Button
			android:id="@+id/createNextDestinationButton"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center_horizontal"
			android:layout_marginTop="14dp"
			android:text="@string/create_next_destination" />

	</LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
